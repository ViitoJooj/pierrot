{
    "comments": {
        "blockComment": ["<!--", "-->"]
    },
    "brackets": [
        ["<!--", "-->"],
        ["<", ">"],
        ["{", "}"],
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "`", "close": "`", "notIn": ["string", "comment"] },
        { "open": "<!--", "close": "-->", "notIn": ["comment", "string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["'", "'"],
        ["\"", "\""],
        ["`", "`"],
        ["<", ">"]
    ],
    "onEnterRules": [
        {
            "beforeText": "<(?!area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)([_:\\w][_:\\w-.\\d]*)([^/>]*(?!/)>)[^<]*$",
            "afterText": "^<\\/([_:\\w][_:\\w-.\\d]*)\\s*>",
            "action": { "indent": "indentOutdent" }
        }
    ]
}
